-- ==========================================
-- [[ ANTI-CHEAT BYPASS FOR NOCLIP ]]
-- ==========================================
-- NOTE: We do NOT use hookmetamethod(game, "__namecall") because the game
-- detects it and kicks with "namecallInstance detector detected".
-- Instead we use targeted hookfunction on the specific remote only.

local AntiCheatRemote = game:GetService("ReplicatedStorage"):FindFirstChild("c5a6fcf5-232d-4ed3-acc8-622222e596ac")
local AntiCheatFunc = AntiCheatRemote and AntiCheatRemote:FindFirstChild("__FUNCTION")

local noclipEnabled = false

if AntiCheatFunc then
    -- Method 1: Replace OnClientInvoke callback to return clean data when noclipping
    pcall(function()
        local realCallback = getcallbackvalue(AntiCheatFunc, "OnClientInvoke")
        if realCallback then
            AntiCheatFunc.OnClientInvoke = function(...)
                if noclipEnabled then
                    return { true, n = 1 }
                end
                return realCallback(...)
            end
        end
    end)

    -- Method 2: Hook FireServer on THIS remote only (not __namecall on game)
    if AntiCheatFunc:IsA("RemoteEvent") then
        pcall(function()
            local oldFire = hookfunction(AntiCheatFunc.FireServer, function(self, ...)
                if noclipEnabled then
                    return
                end
                return oldFire(self, ...)
            end)
        end)
    end

    -- Method 3: Hook InvokeServer on THIS remote only
    if AntiCheatFunc:IsA("RemoteFunction") then
        pcall(function()
            local oldInvoke = hookfunction(AntiCheatFunc.InvokeServer, function(self, ...)
                if noclipEnabled then
                    return { true, n = 1 }
                end
                return oldInvoke(self, ...)
            end)
        end)
    end
end

-- Noclip Stepped connection (runs every frame)
local noclipConnection = nil

local function startNoclip()
    if noclipConnection then return end
    noclipConnection = RunService.Stepped:Connect(function()
        if noclipEnabled and LocalPlayer.Character then
            for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
    end)
end

startNoclip()

