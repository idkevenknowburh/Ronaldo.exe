-- ==========================================
-- [[ ANTI-CHEAT BYPASS FOR NOCLIP ]]
-- ==========================================
-- Based on Cobalt decompilation of the anti-cheat remote:
--   - Game hooks __newindex on game to track OnClientInvoke replacements
--   - OnClientInvoke callback uses isexecutorclosure, getscriptfromthread,
--     debug.info, getthreadidentity to detect tampering
--   - Game periodically verifies OnClientInvoke hasn't changed
--
-- Strategy (3-layer stealth):
--   1. Hook __newindex  → block game from restoring/detecting our replacement
--   2. Hook __index    → fake-read OnClientInvoke so game thinks it's unchanged
--   3. Replace OnClientInvoke with clean callback (returns {true, n=1})
--   4. CanTouch = false in noclip loop (blocks .Touched boundary triggers)

local AntiCheatRemote = game:GetService("ReplicatedStorage"):FindFirstChild("c5a6fcf5-232d-4ed3-acc8-622222e596ac")
local AntiCheatFunc = AntiCheatRemote and AntiCheatRemote:FindFirstChild("__FUNCTION")

local noclipEnabled = false

if AntiCheatFunc then
    -- Save original callback BEFORE any tampering
    local originalCallback = nil
    pcall(function()
        originalCallback = getcallbackvalue(AntiCheatFunc, "OnClientInvoke")
    end)

    -- Layer 1: Hook __newindex on game
    -- The game hooks __newindex to detect when OnClientInvoke is replaced.
    -- We wrap it so the game NEVER sees our replacement go through.
    -- When the game tries to re-set OnClientInvoke (restore original),
    -- we silently block it — our replacement stays in place.
    pcall(function()
        local oldNewIndex = hookmetamethod(game, "__newindex", newcclosure(function(self, key, value, ...)
            if AntiCheatFunc and rawequal(self, AntiCheatFunc) and rawequal(key, "OnClientInvoke") then
                if not checkcaller() then
                    -- Game script trying to set OnClientInvoke — silently swallow
                    -- so it can't restore the original or detect our change
                    return
                end
            end
            return oldNewIndex(self, key, value, ...)
        end))
    end)

    -- Layer 2: Hook __index on game
    -- The game may periodically read OnClientInvoke to verify it's unchanged.
    -- We intercept the read and return the original callback so the game
    -- always sees the "untampered" function.
    -- Roblox's internal InvokeClient uses the REAL property (bypasses __index),
    -- so our replacement still gets called when the server polls.
    pcall(function()
        local oldIndex = hookmetamethod(game, "__index", newcclosure(function(self, key)
            if AntiCheatFunc and rawequal(self, AntiCheatFunc) and rawequal(key, "OnClientInvoke") then
                if not checkcaller() then
                    -- Game script reading OnClientInvoke — return original
                    return originalCallback
                end
            end
            return oldIndex(self, key)
        end))
    end)

    -- Layer 3: Replace OnClientInvoke with our clean callback
    -- Our __newindex hook ensures the game never detects this replacement.
    -- checkcaller() = true here so our hook lets it through.
    pcall(function()
        AntiCheatFunc.OnClientInvoke = function(...)
            if noclipEnabled then
                -- Return clean "not noclipping" data to the server
                return { true, n = 1 }
            end
            -- When noclip is off, pass through to original (or return clean anyway)
            if originalCallback then
                return originalCallback(...)
            end
        end
    end)

    -- Layer 4: Swallow incoming FireClient events from anti-cheat
    if AntiCheatFunc:IsA("RemoteEvent") then
        pcall(function()
            local conn = AntiCheatFunc.OnClientEvent
            if typeof(conn) == "RBXScriptSignal" then
                conn:Connect(function() end)
            end
        end)
    end

    -- Layer 5: Swallow child remote events (additional anti-cheat channels)
    for _, child in ipairs(AntiCheatFunc:GetChildren()) do
        if child:IsA("RemoteEvent") then
            pcall(function()
                child.OnClientEvent:Connect(function() end)
            end)
        end
    end
end

-- Noclip Stepped connection (runs every frame)
local noclipConnection = nil

local function startNoclip()
    if noclipConnection then return end
    noclipConnection = RunService.Stepped:Connect(function()
        if noclipEnabled and LocalPlayer.Character then
            for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                    -- CanTouch = false prevents .Touched events from firing.
                    -- Invisible boundary / kill-zone parts detect you via .Touched;
                    -- without it they never know you passed through.
                    part.CanTouch = false
                end
            end
        end
    end)
end

startNoclip()

