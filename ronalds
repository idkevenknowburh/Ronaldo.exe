-- ============================================
-- [[ VEHICLE NOCLIP ]]
-- ============================================
-- Same approach as player noclip but targets the vehicle model
-- when the player is seated in it.
local vehicleNoclipEnabled = false

RunService.Stepped:Connect(function()
    if not vehicleNoclipEnabled then return end
    local char = LocalPlayer.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid or not humanoid.SeatPart then return end
    local vehicle = humanoid.SeatPart.Parent
    if not vehicle then return end
    -- Apply to the vehicle model and all its descendants
    for _, part in pairs(vehicle:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = false
            part.CanTouch = false
        end
    end
end)

-- ============================================
-- [[ FE FLY SYSTEM ]]
-- ============================================
-- Uses BodyVelocity + BodyGyro on HumanoidRootPart.
-- WASD = horizontal (camera-relative), Space = up, LShift = down.

local flyEnabled = false
local flySpeed = 50
local flyBodyVelocity = nil
local flyBodyGyro = nil
local flyKeys = {
    w = false, a = false, s = false, d = false,
    space = false, shift = false
}

local function createFlyInstances()
    local char = LocalPlayer.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return false end

    -- Clean up old
    if flyBodyVelocity then pcall(function() flyBodyVelocity:Destroy() end) end
    if flyBodyGyro then pcall(function() flyBodyGyro:Destroy() end) end

    flyBodyVelocity = Instance.new("BodyVelocity")
    flyBodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    flyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
    flyBodyVelocity.Parent = hrp

    flyBodyGyro = Instance.new("BodyGyro")
    flyBodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    flyBodyGyro.P = 9000
    flyBodyGyro.D = 100
    flyBodyGyro.CFrame = hrp.CFrame
    flyBodyGyro.Parent = hrp

    humanoid.PlatformStand = true
    return true
end

local function destroyFlyInstances()
    if flyBodyVelocity then pcall(function() flyBodyVelocity:Destroy() end) flyBodyVelocity = nil end
    if flyBodyGyro then pcall(function() flyBodyGyro:Destroy() end) flyBodyGyro = nil end
    local char = LocalPlayer.Character
    if char then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.PlatformStand = false
        end
    end
end

-- Recreate fly instances on character respawn
LocalPlayer.CharacterAdded:Connect(function(char)
    if flyEnabled then
        task.wait(1)
        createFlyInstances()
    end
end)

-- Input handling
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    local kc = input.KeyCode
    if kc == Enum.KeyCode.W then flyKeys.w = true end
    if kc == Enum.KeyCode.A then flyKeys.a = true end
    if kc == Enum.KeyCode.S then flyKeys.s = true end
    if kc == Enum.KeyCode.D then flyKeys.d = true end
    if kc == Enum.KeyCode.Space then flyKeys.space = true end
    if kc == Enum.KeyCode.LeftShift then flyKeys.shift = true end
end)

UserInputService.InputEnded:Connect(function(input)
    local kc = input.KeyCode
    if kc == Enum.KeyCode.W then flyKeys.w = false end
    if kc == Enum.KeyCode.A then flyKeys.a = false end
    if kc == Enum.KeyCode.S then flyKeys.s = false end
    if kc == Enum.KeyCode.D then flyKeys.d = false end
    if kc == Enum.KeyCode.Space then flyKeys.space = false end
    if kc == Enum.KeyCode.LeftShift then flyKeys.shift = false end
end)

-- Movement loop
RunService.RenderStepped:Connect(function()
    if not flyEnabled then return end
    -- Recreate if instances were destroyed
    if not flyBodyVelocity or not flyBodyVelocity.Parent then
        if not createFlyInstances() then return end
    end

    local cam = workspace.CurrentCamera
    if not cam then return end
    local cf = cam.CFrame
    local dir = Vector3.new(0, 0, 0)

    if flyKeys.w then dir = dir + cf.LookVector end
    if flyKeys.s then dir = dir - cf.LookVector end
    if flyKeys.a then dir = dir - cf.RightVector end
    if flyKeys.d then dir = dir + cf.RightVector end
    if flyKeys.space then dir = dir + Vector3.new(0, 1, 0) end
    if flyKeys.shift then dir = dir - Vector3.new(0, 1, 0) end

    if dir.Magnitude > 0 then
        flyBodyVelocity.Velocity = dir.Unit * flySpeed
    else
        flyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
    end

    if flyBodyGyro and flyBodyGyro.Parent then
        flyBodyGyro.CFrame = cf
    end
end)

