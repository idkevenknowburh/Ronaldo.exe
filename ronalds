-- ============================================
-- [[ ANTI-CHEAT BYPASS ]]
-- ============================================
-- Always returns {true, n = 1} — the server always gets "clean" data.
-- Heartbeat loop re-sets if game restores original (O(1) per frame, zero lag).
-- This handles barrier detection which uses the same remote.

local AntiCheatFunc = nil
pcall(function()
    local remote = ReplicatedStorage:FindFirstChild("c5a6fcf5-232d-4ed3-acc8-622222e596ac")
    if remote then
        AntiCheatFunc = remote:FindFirstChild("__FUNCTION")
    end
end)

if AntiCheatFunc then
    -- Always return clean data — never run the original callback
    -- (the original runs isexecutorclosure, getscriptfromthread, debug.info, etc.)
    local cleanCallback = function(...)
        return { true, n = 1 }
    end

    pcall(function()
        AntiCheatFunc.OnClientInvoke = cleanCallback
    end)

    -- Re-set every frame if game restores the original
    RunService.Heartbeat:Connect(function()
        pcall(function()
            if AntiCheatFunc.OnClientInvoke ~= cleanCallback then
                AntiCheatFunc.OnClientInvoke = cleanCallback
            end
        end)
    end)

    -- Swallow incoming FireClient events
    pcall(function()
        if AntiCheatFunc:IsA("RemoteEvent") then
            AntiCheatFunc.OnClientEvent:Connect(function() end)
        end
        for _, child in ipairs(AntiCheatFunc:GetChildren()) do
            if child:IsA("RemoteEvent") then
                child.OnClientEvent:Connect(function() end)
            end
        end
    end)
end

