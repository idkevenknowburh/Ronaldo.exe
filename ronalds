local old_sub = string.sub
local mt = getrawmetatable("") or debug.getmetatable("")
if mt then
    local old_index = mt.__index
    setreadonly(mt, false)
    mt.__index = function(t, k)
        if k == "sub" or k == "slice" then
            return function(str, start, stop)
                -- Safely handle overflow limits
                start = math.clamp(start or 1, -#str, #str)
                stop = math.clamp(stop or #str, -#str, #str)
                return old_sub(str, start, stop)
            end
        end
        if type(old_index) == "function" then
            return old_index(t, k)
        else
            return old_index[k]
        end
    end
    setreadonly(mt, true)
end

