        rayParams.FilterDescendantsInstances = {car}
        local char = LocalPlayer.Character
        if char then
            table.insert(rayParams.FilterDescendantsInstances, char)
        end
        rayParams.FilterType = Enum.RaycastFilterType.Exclude
